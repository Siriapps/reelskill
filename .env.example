# Gemini API key -- aistudio.google.com/apikey (free tier is enough). Required.
GOOGLE_API_KEY=
# Any string you invent; must match what you type in the Meta App Dashboard webhook config. Free.
IG_VERIFY_TOKEN=reelskill-verify
# From your (free) Meta app: generate an Instagram User access token for the receiving
# account. The account must be converted to a professional account (also free).
IG_ACCESS_TOKEN=
# App secret from the Meta App Dashboard (Settings > Basic). Free. Enables webhook signature checks.
IG_APP_SECRET=
# Gemini model for all three agents. gemini-flash-latest is in the free tier.
REELSKILL_MODEL=gemini-flash-latest
# Personal-account mode: reels DM'd to the account are held silently until a message
# containing this word arrives in the thread (like @-mentioning a Slack bot).
# Set empty to process every shared reel immediately (dedicated bot account).
IG_TRIGGER_WORD=claude
# Comma-separated Instagram-scoped sender IDs allowed to use the agent (the server
# logs each sender's ID -- run once, copy yours, paste it here). Empty = allow anyone.
IG_ALLOWED_SENDERS=
